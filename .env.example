# JSON-строка конфигурации Firebase Web App
VITE_FIREBASE_CONFIG={"apiKey":"...","authDomain":"...","projectId":"...","storageBucket":"...","messagingSenderId":"...","appId":"..."}

# Необязательно: appId в коллекции Firestore
VITE_APP_ID=finance-tracker

# Для GitHub Pages выстави base-path репозитория (с завершающим /)
# VITE_BASE_PATH=/no_money/
